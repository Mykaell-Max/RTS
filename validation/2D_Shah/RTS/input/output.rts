!===============================================================
!                         Save Options                          
!===============================================================
.true.      !Save results to csv
.true.      !Save results to vtk
.true.      !Save results to dat
.false.     !Save the mesh position vectors
.false.     !Save wall results to vtk (only for 3D simulations)
.false.     !Nusselt Calculation Module
!==============================================================
!                    Recorded Variables List                    
!===============================================================
.true.    !Temperature               ID 1
.true.    !Incident  radiation       ID 2
.true.    !Divergent rad flux        ID 3
.true.   !Blackbody radiation       ID 4
.true.   !Absorption coefficient    ID 5
.true.   !Scattering coefficient    ID 6
.true.   !Extinction coefficient    ID 7
.false.   !Thermal conductivity      ID 8
.true.   !Radiation emissivities    ID 9
.true.    !Q_radw (only on csv)      ID 10
.false.    !Pressure                  ID 11
.false.    !X_CO2                     ID 12
.false.    !X_H2O                     ID 13  
!===============================================================
!                  Walls Custom Variable Save
!===============================================================
!  WEST    EAST   SOUTH   NORTH   BOTTOM   TOP
 .false. .false. .false. .false. .false. .false. !Temperature
 .false. .false. .false. .false. .false. .false. !Incident  radiation
 .false. .false. .false. .false. .false. .false. !Blackbody radiation
 .true.  .true.  .true.  .true.  .true.  .true.  !Radiative Walls fluxes   ID 10
 .false. .false. .false. .false. .false. .false. !Emissivities at the walls
!===============================================================
!                          Slices Save
!===============================================================
.false.   !on/off slices save module (only for 3D simulations)
 2        !Slicing Method: 1-Percent 2-Point 3-Node
 2        !Number of Slices
!---------------------------------------------------------------
! Axis  Percent  Point   Node    ID
   x      50     0.25d0   10      3 
   x      50     0.75d0   10      3
   z      50     1.00d0   20      1
   x      50     1.0 d0   20      1 
   y      50     1.0 d0   20      1
!<> add more lines if needed
!===============================================================
!                     Lineup Variable Save               
!===============================================================
.false.   !on/off lineup save module (only for 3D simulations)
 1        !Method: 1-Point 2-Node
 4        !Number of Lineups
!---------------------------------------------------------------!
! Axis  >>   X:(x,a,b)   Y:(a,y,b)   Z:(a,b,z)                  !
!---------------------------------------------------------------!
!             CV Point         CV Node      Variable            !
! Axis      a        b        a       b        ID               !
!---------------------------------------------------------------!
   y      1.00d0   1.00d0     10      10        3 
   x      4.00d0   1.00d0     10      10        10
   z      0.25d0   1.00d0     10      10        1
   x      0.25d0   0.00d0     10      10        1
