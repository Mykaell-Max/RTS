!! Main input file. Readed in input_data_amr3d subroutine

!!!****mesh control parameters****!!!
0.0d0 1.0d0 0.0d0 1.0d0 0.0d0 1.0d0            ![a1,b1]x[a2,b2]x[a3,b3]: domain (the largest parallelepiped)
2 2 2                                               ! r:                                        refinement ratio
1                                                   ! ngc:                                      number of ghost cells
1                                                   ! npl:                                      number of physical levels 
42 42 42                                       ! nx_bot, ny_bot, nz_bot:                   number of cells in lbot level   
0.995                                               ! cuttof:                                   goes from 0 to 1, and define how slim is the patch
4                                                   ! bzbl:                                     buffer zone between levels 
2                                                   ! bzfp:                                     buffer zone to flagged points 
.false.                                             ! initial_remesh [true|false]:              remesh in the initial domain configuration (mesh)
.false.                                             ! dynamic_mesh [true|false]:                allow the user to choose if he wants an adaptive mesh
200                                                  ! rfn:                                      number of time step of regriding 
1                                                   ! remesh_type:                              Remesh type: 1- Standard Interp+Project, 2- Popinet Div-free Interp
.false.                                              ! interface_finest_level:                   interface is covered by the finest level
69    0.1d0   0                                      ! flag_refinement,eps_input,vort_lim:       options of refinement: 1- density, 2- ib points, 3- mach, 4- turb visc e 5- vorticity and Control parameters of the refinement criteria 5 (eps_input) and vorticity level limiter (vort_lim)
0                                                   ! read_file_init_patch:                     0: set the initial patch by coordinates, 1: read the initial patch from corner.amr3d file
0                                                   ! number_of_initial_patchs:                 number of initial patches

!!!!*****Pressure velocity coupling and discretization models*****!!!!
1 3 1d-05                                           ! kind_pressure_velocity_coupling, maxNumberIterat, maxDivergIterat:    Type of pressure velocity coupling (1-F.S., 2-SIMPLE, 3-SIMPLEC); maximum number of iterations(SIMPLE, SIMPLEC);   maximum divergent(SIMPLE, SIMPLEC)
0.8d0 0.6d0 0.4d0 0.4d0                             ! relaxVeloc, relaxPres, relaxTempera,relaxconcentrations:              Relaxation coefficient of velocity(SIMPLE, SIMPLEC); Relaxation coefficient of pressure(SIMPLE); !Relaxation coefficient of temperature(SIMPLE, SIMPLEC); !Relaxation coefficient of concentrations(SIMPLE, SIMPLEC)
1	                                            ! temporal_discretization_model:                                        temporal discretization model: 1 semi-implicit , 2 implicit 
"sbdf"                                              ! implicit_disc:                                                        time discretization -"sbdf","mcnab","abcn","cnlf"
1       	                                    ! kindConser:                                                           Conservative form: 1, not conservative form: 2
"cubista"                                           ! advection_model:                                                      IMPLICIT: upwind1O, upwind2O, CDS, QUICK, QUICKhayase;   SEMI-IMPLICIT: upwind1O, upwind2O, godunov, Barton, MSOU, CDS, skew, cubista
2                                                   ! flux_momentum:                                                        flux discretization at momentum equation: 1- malalasekera, 2- traditional  
0.7d0                                               ! cflGlobal:                                                            Courant–Friedrichs–Lewy condition, CFL
.false. 1d-4                                        ! use_dtcte, dtcte:                                                     Flag dt constant [true|false]; dt value if use_dtcte = true
.false. 0.5 0.5                                     ! PseudoTransient, SolvRelaxVel, SolvRelaxSca:                          Pseudo transient [true|false]; Relaxation Factors for velocity and scalars
10                                                  ! ct_ramp:                                                              Rampa inicial
.false.                                             ! buffer_zone:                                                          Buffer zone to damping a region

!!!****multigrid control parameters****!!!
10                                                  ! nvcmax:                                   maximum number of v-cycles or w-cycles
3                                                   ! smoothers_pressure:                       smoothers options: 1- gsrb, 2- msip, 3- sip, 4- cg, 5- bicgstab
.false.                                             ! redblack:                                 red black smooth at pressure multigrid
1d0                                                 ! omeg:                                     over relaxation parameter at pressure multigrid
1.3d0                                               ! omegv:                                    over relaxation parameter at velocity multigrid
1d0                                                 ! omegs:                                    over relaxation parameter at scalar multigrid
1                                                   ! multigrid_technique:                      solver pressure :1- v_cycle, 2 - PETScVI
3                                                   ! vel_solvers:                              solver velocity :1- v_cycle, 2 - PETSc, 3 - SIP 
.false.                                             ! updt_mat [true|false]:                    PETSc update matrix?
.false. 0                                           ! matricial_lbase, petsc_level:             PETSc at lbase level [true|false], wicevel? (petsc_level=lbot-petsc_level)
5 3 2                                               ! relax_base,relax_down,relax_up:           number of smoothness in the 2x2x2 level (relax_base), in down process (relax_down) and in up process (relax_up)

!!!****two-phase control parameters****!!!
1.1949686702345306 1.1949686702345306               !density at continuous phase and disperse phase (dens_phase_c,dens_phase_d)h l
2.189161101643305e-05 2.189161101643305e-05         !viscosity at continuous phase and disperse phase (visc_phase_c,visc_phase_d)
0.0d0                                               !surface tension (surface_tension)
0.0d0 0.0d0 -9.81d0                                     !gravity acceleration (gravity_x, gravity_y, gravity_z)

!!!****simulations control parameters****!!!
.true.                                              ! enable_restart [true|false]:              enables restart generation
.false.                                             ! re_start [true|false]:                    allow the user to choose if he wants to restart the code
.false.                                             ! restart_hdf5 [true|false]:                indicates if meshes for restart should use hdf5 data or not
1                                                   ! restart_counter:                          indicate if restart must be generated by timestep (1) or time (2)
200                                                 ! ctrst:                                    save the data each xxx time step to restart the code
50d-3                                               ! tmrst:                                    save the data each xxx time to restart the code
000212599                                           ! rct:                                      code restart point. Please check the folder "restart/". (USE THE SAME EXPRESSION AFTER "ct_")
1                                                   ! output_counter:                           indicate if output must be generated by timestep (1) or time (2) 
1500                                                ! prt:                                      number of time steps to print the results
25d-3                                               ! tmprt:                                    print results each xxx time 
1                                                   ! ctmax:                                    maximum number of time steps 
900.0d0                                             ! final_t:                                  final time of simulation 
.false.                                             ! output_after_restart:                     generate output after restart
"hdf5"                                              ! printing:                                 printing format: "tecplot"; "paraview"; "hdf5"

!!!****boundary conditions control parameter ****!!!
0 0 0                                               ! x_periodic, y_periodic, z_periodic:       periodic boundary conditions: (0 -> no periodic, 1 -> periodic)
!!!**** alfa u + beta du/dn + gamma du/dt = g****!!!!!
!########### U velocity boundary conditions ############
1.0d0  0.0d0  0.0d0                                 ! ubc_w (alfa_bc,beta_bc,gamma_bc):         u boundary condition at WEST face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! ubc_e (alfa_bc,beta_bc,gamma_bc):         u boundary condition at EAST face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! ubc_s (alfa_bc,beta_bc,gamma_bc):         u boundary condition at SOUTH face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! ubc_n (alfa_bc,beta_bc,gamma_bc):         u boundary condition at NORTH face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! ubc_b (alfa_bc,beta_bc,gamma_bc):         u boundary condition at BOTTOM face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! ubc_t (alfa_bc,beta_bc,gamma_bc):         u boundary condition at TOP face (alfa, beta, gamma)
!########### V velocity boundary conditions ############
1.0d0  0.0d0  0.0d0                                 ! vbc_w (alfa_bc,beta_bc,gamma_bc):         v boundary condition at WEST face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! vbc_e (alfa_bc,beta_bc,gamma_bc):         v boundary condition at EAST face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! vbc_s (alfa_bc,beta_bc,gamma_bc):         v boundary condition at SOUTH face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! vbc_n (alfa_bc,beta_bc,gamma_bc):         v boundary condition at NORTH face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! vbc_b (alfa_bc,beta_bc,gamma_bc):         v boundary condition at BOTTOM face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! vbc_t (alfa_bc,beta_bc,gamma_bc):         v boundary condition at TOP face (alfa, beta, gamma)
!########### W velocity boundary conditions ############
1.0d0  0.0d0  0.0d0                                 ! wbc_w (alfa_bc,beta_bc,gamma_bc):         w boundary condition at WEST face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! wbc_e (alfa_bc,beta_bc,gamma_bc):         w boundary condition at EAST face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! wbc_s (alfa_bc,beta_bc,gamma_bc):         w boundary condition at SOUTH face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! wbc_n (alfa_bc,beta_bc,gamma_bc):         w boundary condition at NORTH face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! wbc_b (alfa_bc,beta_bc,gamma_bc):         w boundary condition at BOTTOM face (alfa, beta, gamma)
1.0d0  0.0d0  0.0d0                                 ! wbc_t (alfa_bc,beta_bc,gamma_bc):         w boundary condition at TOP face (alfa, beta, gamma)
!########### pressure boundary conditions ############
0.0d0  1.0d0  0.0d0                                 ! pbc_w (alfa_bc,beta_bc,gamma_bc):         p boundary condition at WEST face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! pbc_e (alfa_bc,beta_bc,gamma_bc):         p boundary condition at EAST face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! pbc_s (alfa_bc,beta_bc,gamma_bc):         p boundary condition at SOUTH face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! pbc_n (alfa_bc,beta_bc,gamma_bc):         p boundary condition at NORTH face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! pbc_b (alfa_bc,beta_bc,gamma_bc):         p boundary condition at BOTTOM face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! pbc_t (alfa_bc,beta_bc,gamma_bc):         p boundary condition at TOP face (alfa, beta, gamma)
!########### density boundary conditions ##############
0.0d0  1.0d0  0.0d0                                 ! rbc_w (alfa_bc,beta_bc,gamma_bc):         density boundary condition at WEST face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! rbc_e (alfa_bc,beta_bc,gamma_bc):         density boundary condition at EAST face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! rbc_s (alfa_bc,beta_bc,gamma_bc):         density boundary condition at SOUTH face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! rbc_n (alfa_bc,beta_bc,gamma_bc):         density boundary condition at NORTH face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! rbc_b (alfa_bc,beta_bc,gamma_bc):         density boundary condition at BOTTOM face (alfa, beta, gamma)
0.0d0  1.0d0  0.0d0                                 ! rbc_t (alfa_bc,beta_bc,gamma_bc):         densityp boundary condition at TOP face (alfa, beta, gamma)

!!!****initial partition topology****!!!
1 1 1                                               ! npx, npy, npz:                            number of processors in x,y,z axis

!!!****Loadbalance controls
.false.                                             ! lb_enabled [true|false]:      Enalbes load balance. Default: false
1                                                   ! lb_policy:                    loadbalancing policy, if enabled: 1 -> all remesh; 2 -> only first remesh; 3 -> by treshold; 4 -> by ToT analysis; 5 -> automatic criteria
1                                                   ! lb_pol_treshold:              loadbalancing policy by treshold, if enabled: 1 -> until remesh; 2 -> after remesh; 3 -> until iteration; 4 -> after iteration; 5 -> after ToT diff
1                                                   ! lb_treshold:                  treshold for enabling or disabling loadbalancing (if lb_pol_treshold = 1, 2, 3, 4)
50                                                  ! ToT_stats_num:                how many ToT's (and remesh ToT's) should be recorded into memory 
5d0 5d0                                             ! ToT_diff_med_treshold, remesh_ToT_diff_med_treshold:      ToT's (or remesh ToT's) median treshold for enabling/disabling loadbalance
30 10                                               ! ToT_tendency_treshold, remesh_ToT_tendency_treshold:      how many ToT's (or remesh ToT's) from memory should be considered when analysing tendency

!!!****Start by HDF5
false                                               ! use_start_hdf5 [true|false]:              use start by hdf5
"start.hdf5"                                        ! hdf5_start_file:                          hdf5 file

!!!**** Method
1                                                   ! method_mode:                              1 - Noone; 2 - IB; 3 - VoF; 4 - FT; 5 - VoF+IB; 6 - FT+IB

